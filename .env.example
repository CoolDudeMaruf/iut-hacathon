# ---- Web server ----
PORT=3000

# ---- Discord bot (optional) ----
# Leave DISCORD_TOKEN empty to run the dashboard + API without the bot.
DISCORD_TOKEN=
# Channel ID the bot proactively posts alerts to (right-click a channel > Copy ID).
ALERT_CHANNEL_ID=
# Command prefix for the bot.
BOT_PREFIX=!

# ---- LLM (optional): Gemini preferred, Groq as a fallback ----
# The bot uses whichever key is set to phrase answers conversationally. With
# neither, it still works using friendly built-in templates.
#
# Gemini key (starts with AIza...) from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
#
# Groq key (starts with gsk_) from https://console.groq.com/keys — used only if
# GEMINI_API_KEY is empty.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
